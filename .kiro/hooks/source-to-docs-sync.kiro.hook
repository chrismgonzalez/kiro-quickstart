{
  "enabled": true,
  "name": "Source to Docs Sync",
  "description": "Monitors source file changes and proposes updates to documentation to keep them in sync with the codebase.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Use the /docs skill to check for documentation drift and propose updates. All documentation is stored in /docs."
  }
}
