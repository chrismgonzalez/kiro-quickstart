{
  "enabled": true,
  "name": "Source to Docs Sync",
  "description": "Monitors source file changes and proposes updates to documentation to keep them in sync with the codebase.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Source files have been modified. Use the 'docs' skill to check for documentation drift and propose updates. The docs skill will:\n\n1. Discover existing documentation\n2. Analyze what changed semantically\n3. Map changes to affected documentation\n4. Produce a sync report with proposed updates\n5. Wait for approval before applying changes\n\nFocus on these documentation areas:\n- code-index.md (always check for new/changed/deleted files)\n- README.md (high-level features)\n- Any other documentation files in the project\n\nIf no documentation changes are needed, briefly explain why."
  }
}
